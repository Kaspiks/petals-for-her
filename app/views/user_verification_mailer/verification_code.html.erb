<% code_display = @verification_code.to_s.scan(/.{1,3}/).join(' ') %>
<% code_chars = @verification_code.to_s.chars %>
<!-- Outer wrapper: light background, card with shadow -->
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background: #FAF9F6; padding: 32px 16px; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;">
  <tr>
    <td align="center">
      <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="max-width: 600px; width: 100%; background: #FFFEFB; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.08); overflow: hidden;">
        <!-- Header banner: roses image with brand overlay -->
        <tr>
          <td style="padding: 0; text-align: center; line-height: 0;">
            <% if @email_banner_url.present? %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
                <tr>
                  <td style="padding: 0;">
                    <img src="<%= @email_banner_url %>" alt="" width="600" style="display: block; width: 100%; max-width: 600px; height: auto; vertical-align: top;" />
                  </td>
                </tr>
                <tr>
                  <td style="padding: 16px 24px 0; text-align: center;">
                    <span style="display: inline-block; padding: 12px 28px; background: #ffffff; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.1); font-size: 18px; font-weight: 600; color: #1f2937;">Petals for Her</span>
                  </td>
                </tr>
              </table>
            <% else %>
              <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="background: linear-gradient(160deg, #E8B4BC 0%, #D4A5A5 35%, #C4959A 70%, #B8858F 100%);">
                <tr>
                  <td style="height: 160px; vertical-align: middle; text-align: center; padding: 20px;">
                    <span style="display: inline-block; padding: 12px 28px; background: #ffffff; border-radius: 8px; box-shadow: 0 2px 12px rgba(0,0,0,0.1); font-size: 18px; font-weight: 600; color: #1f2937;">Petals for Her</span>
                  </td>
                </tr>
              </table>
            <% end %>
          </td>
        </tr>
        <!-- Floral icon -->
        <tr>
          <td style="padding: 24px 24px 4px; text-align: center;">
            <span style="font-size: 28px; color: #B5659E;">✿</span>
          </td>
        </tr>
        <!-- Heading -->
        <tr>
          <td style="padding: 0 24px 8px; text-align: center;">
            <h1 style="margin: 0; font-size: 26px; font-weight: 700; color: #1f2937;">Welcome to the <em style="font-style: italic;">Scent Circle</em></h1>
          </td>
        </tr>
        <!-- Body text -->
        <tr>
          <td style="padding: 0 24px 24px; text-align: center;">
            <p style="margin: 0; font-size: 15px; color: #6B7280; line-height: 1.6;">Thank you for joining our community of floral elegance. Please use the code below to verify your email address and bloom with us.</p>
          </td>
        </tr>
        <!-- Verification code (prominent box, olive green) -->
        <tr>
          <td style="padding: 0 24px 24px; text-align: center;">
            <table role="presentation" cellspacing="0" cellpadding="0" border="0" style="margin: 0 auto;">
              <tr>
                <td style="padding: 20px 40px; background: #F7FBF5; border: 2px solid #9CB88A; border-radius: 10px;">
                  <span style="font-size: 32px; font-weight: 700; color: #556B2F; letter-spacing: 6px;"><%= code_display %></span>
                </td>
              </tr>
            </table>
          </td>
        </tr>
        <!-- Verify button (vibrant magenta) -->
        <tr>
          <td style="padding: 0 24px 28px; text-align: center;">
            <a href="<%= @verify_url %>" style="display: inline-block; padding: 14px 36px; background: #D81B60; color: #ffffff !important; font-size: 15px; font-weight: 600; text-decoration: none; border-radius: 8px;">
              Verify Your Account →
            </a>
          </td>
        </tr>
        <!-- Separator -->
        <tr>
          <td style="padding: 0 24px 24px;">
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0"><tr><td style="border-top: 1px solid #E5E7EB;"></td></tr></table>
          </td>
        </tr>
        <!-- Manual code entry -->
        <tr>
          <td style="padding: 0 24px 24px; text-align: center;">
            <p style="margin: 0 0 14px; font-size: 14px; color: #9CA3AF;">Or enter the code manually:</p>
            <table role="presentation" cellspacing="8" cellpadding="0" border="0" style="margin: 0 auto;">
              <tr>
                <% code_chars.each do |digit| %>
                  <td style="width: 40px; height: 48px; background: #ffffff; border: 1px solid #E5E7EB; border-radius: 8px; text-align: center; vertical-align: middle;">
                    <span style="font-size: 20px; font-weight: 600; color: #1f2937;"><%= digit %></span>
                  </td>
                <% end %>
              </tr>
            </table>
          </td>
        </tr>
        <!-- Closing -->
        <tr>
          <td style="padding: 28px 24px 16px; text-align: center;">
            <p style="margin: 0 0 4px; font-size: 15px; color: #374151;">With Fragrant Wishes,</p>
            <p style="margin: 0; font-size: 15px; font-weight: 600; color: #374151;">The Petals Team</p>
          </td>
        </tr>
        <!-- Social icons (placeholder circles – replace with your icon links) -->
        <tr>
          <td style="padding: 0 24px 24px; text-align: center;">
            <a href="#" style="display: inline-block; width: 32px; height: 32px; margin: 0 6px; background: #9CA3AF; border-radius: 50%; text-decoration: none; color: transparent;">F</a>
            <a href="#" style="display: inline-block; width: 32px; height: 32px; margin: 0 6px; background: #9CA3AF; border-radius: 50%; text-decoration: none; color: transparent;">I</a>
            <a href="#" style="display: inline-block; width: 32px; height: 32px; margin: 0 6px; background: #9CA3AF; border-radius: 50%; text-decoration: none; color: transparent;">E</a>
          </td>
        </tr>
        <!-- Footer -->
        <tr>
          <td style="padding: 24px; border-top: 1px solid #E5E7EB; text-align: center; background: #F9FAFB;">
            <p style="margin: 0 0 8px; font-size: 12px; color: #9CA3AF;">© <%= Time.current.year %> Petals for Her. All rights reserved.</p>
            <p style="margin: 0 0 8px; font-size: 11px; color: #9CA3AF;">Brivibas iela 10, Riga, Latvia</p>
            <p style="margin: 0; font-size: 11px;"><a href="#" style="color: #9CA3AF; text-decoration: underline;">Unsubscribe</a></p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>
