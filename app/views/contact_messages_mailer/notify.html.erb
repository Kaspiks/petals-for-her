<% opts = Rails.application.config.action_mailer.default_url_options %>
<% base_host = opts[:host] || 'localhost' %>
<% base_port = opts[:port] %>
<% frontend_port = base_port == 3000 ? 5173 : (base_port || 80) %>
<% frontend_url = "http://#{base_host}:#{frontend_port}" %>
<table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0" style="max-width: 600px; margin: 0 auto; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif; font-size: 16px; line-height: 1.6; color: #374151; background: #ffffff;">
  <!-- Header -->
  <tr>
    <td style="padding: 32px 24px 24px; text-align: center;">
      <div style="font-size: 24px; margin-bottom: 4px;">✦</div>
      <h1 style="margin: 0; font-size: 24px; font-weight: 600; color: #111827;">Petals for Her</h1>
      <div style="height: 1px; background: #E5E7EB; margin: 24px 0;"></div>
      <span style="display: inline-block; padding: 6px 14px; background: #D1FAE5; color: #047857; font-size: 11px; font-weight: 600; letter-spacing: 0.5px; border-radius: 20px;">NEW INQUIRY</span>
      <h2 style="margin: 16px 0 8px; font-size: 22px; font-weight: 700; color: #111827;">Customer Contact Message</h2>
      <p style="margin: 0; font-size: 14px; color: #6B7280;">A new boutique inquiry has arrived.</p>
    </td>
  </tr>
  <!-- Inquiry details -->
  <tr>
    <td style="padding: 0 24px 24px;">
      <table role="presentation" width="100%" cellspacing="0" cellpadding="20" border="0" style="background: #F9FAFB; border-radius: 8px; border: 1px solid #E5E7EB;">
        <tr>
          <td>
            <table role="presentation" width="100%" cellspacing="0" cellpadding="0" border="0">
              <tr>
                <td style="padding-bottom: 16px;">
                  <p style="margin: 0 0 4px; font-size: 11px; font-weight: 600; color: #9CA3AF; letter-spacing: 0.5px;">SENDER NAME</p>
                  <p style="margin: 0; font-size: 15px; font-weight: 500; color: #111827;"><%= h(@contact_message.name) %></p>
                </td>
              </tr>
              <tr>
                <td style="padding-bottom: 16px;">
                  <p style="margin: 0 0 4px; font-size: 11px; font-weight: 600; color: #9CA3AF; letter-spacing: 0.5px;">EMAIL ADDRESS</p>
                  <a href="mailto:<%= h(@contact_message.email) %>" style="color: #4F6D65; text-decoration: underline; font-size: 15px;"><%= h(@contact_message.email) %></a>
                </td>
              </tr>
              <tr>
                <td style="padding-bottom: 16px;">
                  <p style="margin: 0 0 4px; font-size: 11px; font-weight: 600; color: #9CA3AF; letter-spacing: 0.5px;">SUBJECT</p>
                  <p style="margin: 0; font-size: 15px; font-weight: 600; color: #111827;"><%= h(@contact_message.subject) %></p>
                </td>
              </tr>
              <tr>
                <td>
                  <p style="margin: 0 0 4px; font-size: 11px; font-weight: 600; color: #9CA3AF; letter-spacing: 0.5px;">MESSAGE BODY</p>
                  <p style="margin: 0; padding: 12px; background: #ffffff; border-radius: 6px; border-left: 4px solid #4F6D65; font-size: 14px; color: #6B7280; font-style: italic; white-space: pre-wrap;"><%= h(@contact_message.message) %></p>
                </td>
              </tr>
            </table>
          </td>
        </tr>
      </table>
    </td>
  </tr>
  <!-- Reply button -->
  <tr>
    <td style="padding: 0 24px 24px; text-align: center;">
      <a href="mailto:<%= h(@contact_message.email) %>?subject=Re:%20<%= ERB::Util.url_encode(@contact_message.subject) %>" style="display: inline-block; padding: 14px 28px; background: #4F6D65; color: #ffffff !important; font-size: 14px; font-weight: 600; text-decoration: none; border-radius: 8px; letter-spacing: 0.3px;">
        ← Reply to Customer
      </a>
      <p style="margin: 12px 0 0; font-size: 12px; color: #9CA3AF;">TYPICAL RESPONSE TIME: &lt; 2 HOURS</p>
    </td>
  </tr>
  <!-- Footer -->
  <tr>
    <td style="padding: 24px; border-top: 1px solid #E5E7EB; text-align: center;">
      <p style="margin: 0 0 16px; font-size: 12px; color: #9CA3AF;">This is an automated notification from the Petals for Her customer management system.</p>
      <p style="margin: 0; font-size: 11px; color: #9CA3AF;">
        <a href="<%= frontend_url %>/admin" style="color: #4F6D65; text-decoration: none;">ADMIN DASHBOARD</a>
        &nbsp;•&nbsp;
        <a href="<%= frontend_url %>/privacy_policy" style="color: #4F6D65; text-decoration: none;">PRIVACY POLICY</a>
      </p>
    </td>
  </tr>
</table>
