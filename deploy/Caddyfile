# Caddy reverse proxy for Petals for Her
# Serves React frontend and proxies /api to Rails. Auto HTTPS via Let's Encrypt.

# One canonical host: www → apex (must match APP_HOST and sitemap URLs, or GSC reports
# "Duplicate, Google chose different canonical than user" when canonical uses www).
# Replace petalsforher.com if you use a different primary domain.
www.petalsforher.com {
	redir https://petalsforher.com{uri} permanent
}

# Replace with your apex domain only (not www — www is redirected above).
petalsforher.com {
	# API requests go to Rails
	handle /api/* {
		reverse_proxy web:3000
	}
	# Health check (optional, for monitoring)
	handle /up {
		reverse_proxy web:3000
	}
	# Sitemap (generated by Rails). Must hit Rails — if this falls through to SPA try_files,
	# Google Search Console reports "Sitemap is HTML" (index.html).
	@sitemap path /sitemap.xml
	handle @sitemap {
		reverse_proxy web:3000
	}
	# Frontend: static files + SPA fallback
	handle {
		root * /srv/frontend
		file_server
		try_files {path} /index.html
	}
}
