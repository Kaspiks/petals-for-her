# Caddy reverse proxy for Petals for Her
# Serves React frontend and proxies /api to Rails. Auto HTTPS via Let's Encrypt.

# Replace with your domain, e.g. petalsforher.com www.petalsforher.com
petalsforher.com www.petalsforher.com {
	# API requests go to Rails
	handle /api/* {
		reverse_proxy web:3000
	}
	# Health check (optional, for monitoring)
	handle /up {
		reverse_proxy web:3000
	}
	# Frontend: static files + SPA fallback
	handle {
		root * /srv/frontend
		file_server
		try_files {path} /index.html
	}
}
