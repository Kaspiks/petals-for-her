# Petals for Her – Production environment
# Copy to .env.production in project root, or pass via --env-file deploy/.env.production
# On the server, put this at /opt/petals-for-her/.env or the same directory as docker-compose.prod.yml

# Rails
SECRET_KEY_BASE=generate_with_rails_secret
RAILS_MASTER_KEY=contents_of_config_master_key

# Database (must match POSTGRES_* in db service)
DATABASE_USERNAME=petals_for_her
DATABASE_PASSWORD=change_me_secure_password
DATABASE_NAME=petals_for_her_production

# App URL for mailers and redirects (no protocol; Caddy handles HTTPS)
APP_HOST=petalsforher.com

# JWT secret for Devise (e.g. run: openssl rand -hex 32)
DEVISE_JWT_SECRET_KEY=change_me_openssl_rand_hex_32
