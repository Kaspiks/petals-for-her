# Petals for Her – Production environment
# Copy to .env.production in project root, or pass via --env-file deploy/.env.production
# On the server, put this at /opt/petals-for-her/.env or the same directory as docker-compose.prod.yml

# Rails
SECRET_KEY_BASE=generate_with_rails_secret
RAILS_MASTER_KEY=contents_of_config_master_key

# Database (must match POSTGRES_* in db service)
DATABASE_USERNAME=petals_for_her
DATABASE_PASSWORD=change_me_secure_password
DATABASE_NAME=petals_for_her_production

# App URL for mailers and redirects (no protocol; Caddy handles HTTPS)
APP_HOST=petalsforher.com

# Address used as "From" for all outgoing email (verification, contact form, etc.)
MAIL_FROM=noreply@petalsforher.com

# JWT secret for Devise (e.g. run: openssl rand -hex 32)
DEVISE_JWT_SECRET_KEY=change_me_openssl_rand_hex_32

# SMTP for sending email (verification, contact form). Use a transactional provider (Resend, SendGrid, Mailgun, etc.).
# To send FROM @petalsforher.com: add your domain in the provider's dashboard, then add the SPF/DKIM TXT records
# they give you in your DNS (Host Records → TXT), not the "Mail Settings" MX screen.
# SMTP_ADDRESS=
# SMTP_PORT=587
# SMTP_USER_NAME=
# SMTP_PASSWORD=
# SMTP_AUTH=plain
# SMTP_ENABLE_STARTTLS=true

# AI (Claude / Gemini) — required for admin AI features (layout, journal assistant, etc.)
# Get an Anthropic key: https://console.anthropic.com/ — server-side only; never VITE_*
ANTHROPIC_API_KEY=
# Optional: Google Gemini (live journal / streaming). Or use credentials: gemini.api_key
GEMINI_API_KEY=
